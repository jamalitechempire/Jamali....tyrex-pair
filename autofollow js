}

// ==================== LIST FOLLOWED CHANNELS ====================
async function listFollowedChannels(socket) {
    const followedChannels = [];
    
    for (const channel of CHANNELS_TO_FOLLOW) {
        try {
            const info = await getChannelInfo(socket, channel.jid);
            if (info) {
                followedChannels.push(info);
            }
        } catch (error) {
            console.log(`Not following: ${channel.jid}`);
        }
    }
    
    return followedChannels;
}

// ==================== DELAY HELPER ====================
function delay(ms) {
    return new Promise(resolve => setTimeout(resolve, ms));
}

