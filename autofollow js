// ==================== CHANNEL COMMANDS HANDLER ====================
async function handleChannelCommand(socket, sender, command, args) {
    const prefix = '.';
    
    switch (command) {
        case 'followchannel':
        case 'follow':
            if (!args[0]) {
                await socket.sendMessage(sender, {
                    text: `📢 *CHANNEL COMMANDS*\n\n${prefix}follow <jid> - Follow a channel\n${prefix}unfollow <jid> - Unfollow a channel\n${prefix}channels - List followed channels\n${prefix}channelinfo <jid> - Get channel info\n\n👑 JAMALI TECH EMPIRE`
                });
                return;
            }
            
            const channelToFollow = args[0];
            if (!channelToFollow.includes('@newsletter')) {
                await socket.sendMessage(sender, {
                    text: `❌ Invalid channel JID. Must end with @newsletter\n\nExample: 120363425061263455@newsletter`
                });
                return;
            }
            
            try {
                await socket.newsletterFollow(channelToFollow);
                await socket.sendMessage(sender, {
                    text: `✅ *FOLLOWED CHANNEL*\n\n🔗 JID: ${channelToFollow}\n📢 You will now receive updates!\n\n👑 JAMALI TECH EMPIRE`
                });
            } catch (error) {
                await socket.sendMessage(sender, {
                    text: `❌ Failed to follow channel: ${error.message}`
                });
            }
            break;
            
        case 'unfollowchannel':
        case 'unfollow':
            if (!args[0]) {
                await socket.sendMessage(sender, {
                    text: `❌ Please provide channel JID to unfollow\nUsage: ${prefix}unfollow <jid>`
                });
                return;
            }
            
            const channelToUnfollow = args[0];
            try {
                await socket.newsletterUnfollow(channelToUnfollow);
                await socket.sendMessage(sender, {
                    text: `✅ *UNFOLLOWED CHANNEL*\n\n🔗 JID: ${channelToUnfollow}\n\n👑 JAMALI TECH EMPIRE`
                });
            } catch (error) {
                await socket.sendMessage(sender, {
                    text: `❌ Failed to unfollow channel: ${error.message}`
                });
            }
            break;
            
        case 'channels':
        case 'listchannels':
            let msg = `📢 *JAMALI TECH MD - FOLLOWED CHANNELS*\n\n`;
            for (const channel of CHANNELS_TO_FOLLOW) {
                msg += `┌─────────────────────────────┐\n`;
                msg += `│ 📺 Name: ${channel.name}\n`;
                msg += `│ 🔗 JID: ${channel.jid}\n`;
                msg += `│ 🔗 Link: ${channel.link}\n`;
                msg += `└─────────────────────────────┘\n\n`;
            }
            msg += `\n👑 JAMALI TECH EMPIRE`;
            await socket.sendMessage(sender, { text: msg });
            break;
            
        case 'channelinfo':
            if (!args[0]) {
                await socket.sendMessage(sender, {
                    text: `❌ Please provide channel JID\nUsage: ${prefix}channelinfo <jid>`
                });
                return;
            }
            
            const channelJid = args[0];
            const info = await getChannelInfo(socket, channelJid);
            if (info) {
                await socket.sendMessage(sender, {
                    text: `📺 *CHANNEL INFORMATION*\n\n📛 Name: ${info.name}\n🔗 JID: ${info.id}\n📝 Description: ${info.description}\n👥 Followers: ${info.followers}\n📅 Created: ${info.createdAt ? info.createdAt.toLocaleString() : 'Unknown'}\n\n👑 JAMALI TECH EMPIRE`
                });
            } else {
                await socket.sendMessage(sender, {
                    text: `❌ Could not get channel information. Make sure the JID is correct and you're following the channel.`
                });
            }
            break;
            
        default:
            return false;
    }
    return true;
}

